# ============================================================
# Konfigurasi OLT Monitoring Bot
# Salin file ini menjadi .env dan isi nilainya
# JANGAN commit file .env ke Git
# ============================================================

# ── KONFIGURASI TELEGRAM ─────────────────────────────────────
# Token dari @BotFather di Telegram
BOT_TOKEN=ISI_TOKEN_BARU_ANDA_DISINI

# Chat ID Anda (bisa dicek via @userinfobot)
ADMIN_CHAT_ID=ISI_CHAT_ID_ANDA

# ── KONFIGURASI OLT (SNMP) ───────────────────────────────────
# IP Address OLT VSOL Anda
OLT_IP=10.10.0.200

# SNMP Community String (default: public)
OLT_COMMUNITY=public

# ── KONFIGURASI MONITORING ───────────────────────────────────
# Interval cek status ONU dalam detik (default: 60)
CHECK_INTERVAL=60

# Berapa kali SNMP gagal berturut-turut sebelum dianggap OLT down (default: 2)
OLT_DOWN_THRESHOLD=2

# Rate limit command per user dalam detik (default: 5)
COOLDOWN_SECONDS=5

# Durasi tunggu setelah OLT/jaringan pulih sebelum monitoring aktif kembali (detik).
STABILIZATION_WINDOW=300

# Grace period sebelum notif "Mati Listrik" dikirim (detik).
POWER_GRACE_PERIOD=300
