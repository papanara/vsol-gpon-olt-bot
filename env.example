# ============================================================
# Konfigurasi OLT Monitoring Bot
# Salin file ini menjadi .env dan isi nilainya
# JANGAN commit file .env ke Git
# ============================================================

# Token dari @BotFather di Telegram
BOT_TOKEN=ISI_TOKEN_BARU_ANDA_DISINI

# Chat ID Anda (bisa dicek via @userinfobot)
ADMIN_CHAT_ID=ISI_CHAT_ID_ANDA

# Interval cek status ONU dalam detik (default: 60)
CHECK_INTERVAL=60

# Durasi tunggu setelah OLT/jaringan pulih sebelum monitoring aktif kembali (detik).
# Fungsi: mencegah banjir notif saat mati lampu total atau OLT restart.
# ONU butuh waktu untuk naik kembali — beri waktu yang cukup.
# Rekomendasi: 300 (5 menit). Set 0 untuk nonaktifkan.
STABILIZATION_WINDOW=300

# Grace period sebelum notif "Mati Listrik" dikirim (detik).
# ONU harus konsisten mati selama durasi ini sebelum Anda dinotifikasi.
# Tujuan: mencegah notif dari client yang hanya pindah colokan sesaat.
# Status LOS (kabel putus) TIDAK terpengaruh — selalu notif langsung.
# Rekomendasi: 300 (5 menit). Set 0 untuk notif langsung.
POWER_GRACE_PERIOD=300
